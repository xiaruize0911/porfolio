\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Memory--quality Pareto trade-off. Each point represents an ablation variant, plotted as peak GPU memory (GB) versus validation loss (MSE). The dashed line connecting Pareto-optimal points illustrates the efficiency frontier. Our model achieves the lowest loss despite higher memory usage, while the No DiT baseline offers the best memory efficiency at the cost of reduced quality.}}{7}{figure.caption.9}\protected@file@percent }
\newlabel{fig:pareto}{{5}{7}{Memory--quality Pareto trade-off. Each point represents an ablation variant, plotted as peak GPU memory (GB) versus validation loss (MSE). The dashed line connecting Pareto-optimal points illustrates the efficiency frontier. Our model achieves the lowest loss despite higher memory usage, while the No DiT baseline offers the best memory efficiency at the cost of reduced quality}{figure.caption.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Inference latency for generating a single 16-frame clip using 15-step DDIM sampling. The No DiT baseline is fastest (2{,}629\,ms), while our factorized model (2{,}860\,ms) incurs only 8.8\% overhead — well within practical bounds for non-real-time applications.}}{7}{figure.caption.10}\protected@file@percent }
\newlabel{fig:inference}{{6}{7}{Inference latency for generating a single 16-frame clip using 15-step DDIM sampling. The No DiT baseline is fastest (2{,}629\,ms), while our factorized model (2{,}860\,ms) incurs only 8.8\% overhead — well within practical bounds for non-real-time applications}{figure.caption.10}{}}
